---
// src/pages/index.astro
// VWS marketing home — H.A.S.I.T. framework (Headline / Audience / Solution / Identity / Testimonials).
// CTA target: GHL Small Favor 45-min booking widget.

import headshot from "../assets/headshot.png";

export const prerender = true;

const calendarUrl =
  "https://api.velocitywebstudio.com/widget/booking/mcWyJi4NDQ1tg3JDZlYS";

const trustStrip = [
  "5 leads in 60 days, guaranteed",
  "One client per category per city",
  "Month-to-month",
];

const stats = [
  { n: "46%", l: "of all Google searches are local" },
  {
    n: "88%",
    l: "of people who run a local search call or visit within 24 hours",
  },
  { n: "97%", l: "of Google users have used search to find a local business" },
  { n: "900%", l: "growth in “near me” searches in recent years" },
];

const audiencePoints = [
  "You can't answer the phone at 9pm while you're on a job",
  "The competitors ranking above you on Google aren't better — they're just running a system you don't have",
  "You've been sold “marketing services” by people who never installed the system end-to-end",
  "You're trying to do the work and figure out Google and post weekly and chase reviews and respond to leads in 60 seconds",
  "The agencies you've worked with sold you one piece of the puzzle and called it marketing",
];

const differentiators = [
  {
    h: "End-to-end, not piecemeal.",
    p: "Most agencies sell one piece — SEO, or ads, or a website. We install all five: visibility, capture, follow-up, paid traffic, organic SEO. Pieces don't compound. Systems do.",
  },
  {
    h: "Done-for-you, not done-with-you.",
    p: "You don't learn the tools. You don't manage the CRM. You don't post weekly. We run it. You do the work you're already good at.",
  },
  {
    h: "Backed by a guarantee most agencies won't make.",
    p: "5 qualified leads in 60 days, or we work free until you get them. The system has run across niches and service areas enough times for us to put our revenue on the line. We do.",
  },
  {
    h: "One client per category, per city.",
    p: "We're not selling the same playbook to your three nearest competitors. Your win matters to us — that's also why availability is limited.",
  },
  {
    h: "Compounds over time.",
    p: "Campaigns end. Systems compound. The infrastructure we install keeps producing leads after the ad budget pauses. That's the difference between renting leads and owning them.",
  },
];

const testimonials = [
  {
    q: "The missed-call text-back paid for the first 6 months in one week. Caught a roof job that would have gone to a competitor.",
    n: "Carlos R.",
    r: "Painter · Boise, ID",
  },
  {
    q: "I was ranked 8th. Now I'm ranked first in two cities and second in the third. Calls have basically tripled.",
    n: "Lisa M.",
    r: "Med Spa Owner · Eagle, ID",
  },
  {
    q: "I thought I needed to spend on ads. Turns out I just needed someone running the system every week. The needle started moving in week three and hasn't stopped.",
    n: "Daniel",
    r: "HVAC Co. Owner · Ada County, ID",
  },
];

const closeBlocks = [
  {
    h: "Why now",
    p: "We work with one client per category, per city. The slot in your industry, in your service area, is either available right now or it isn't.",
  },
  {
    h: "What happens on the call",
    p: "We look at your current Google presence and lead flow together. No homework, no slide deck. You leave with a free Google Review App — yours forever — and a clear read on what installing the system would change for your business.",
  },
  {
    h: "What you have to lose",
    p: "Nothing. The Review App is yours regardless. The call is free. If we're not a fit, we tell you and point you somewhere useful.",
  },
];
---

<!doctype html>
<html lang="en" data-theme="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>
      Velocity Web Studio — More local customers from Google, guaranteed
    </title>
    <meta
      name="description"
      content="We install the Google-first lead system end-to-end for local service businesses in Boise & the Treasure Valley. 5 qualified leads in 60 days, or we work free until you get them."
    />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link
      href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600;700;800&display=swap"
      rel="stylesheet"
    />
  </head>

  <body>
    <div class="outer">
      <div class="page">
        <header class="topbar">
          <a class="brand" href="/">Velocity <em>Web</em></a>
          <nav class="nav">
            <button
              class="theme-toggle"
              id="themeToggle"
              aria-label="Toggle light/dark mode"
            >
              <svg class="icon-moon" viewBox="0 0 24 24" aria-hidden="true"
                ><path d="M21 12.79A9 9 0 1 1 11.21 3a7 7 0 0 0 9.79 9.79z"
                ></path></svg
              >
              <svg class="icon-sun" viewBox="0 0 24 24" aria-hidden="true"
                ><path
                  d="M12 17a5 5 0 1 0 0-10 5 5 0 0 0 0 10zm0-14a1 1 0 0 1 1 1v1a1 1 0 1 1-2 0V4a1 1 0 0 1 1-1zm0 16a1 1 0 0 1 1 1v1a1 1 0 1 1-2 0v-1a1 1 0 0 1 1-1zm9-9a1 1 0 0 1 0 2h-1a1 1 0 1 1 0-2h1zM5 12a1 1 0 0 1-1 1H3a1 1 0 1 1 0-2h1a1 1 0 0 1 1 1zm12.66-6.24a1 1 0 0 1 0 1.41l-.71.71a1 1 0 1 1-1.41-1.41l.71-.71a1 1 0 0 1 1.41 0zM7.05 17.66a1 1 0 0 1 0 1.41l-.71.71a1 1 0 1 1-1.41-1.41l.71-.71a1 1 0 0 1 1.41 0zm11.32 0a1 1 0 0 1-1.41 1.41l-.71-.71a1 1 0 1 1 1.41-1.41l.71.71zM7.05 6.34a1 1 0 0 1-1.41 0l-.71-.71a1 1 0 0 1 1.41-1.41l.71.71a1 1 0 0 1 0 1.41z"
                ></path></svg
              >
            </button>
            <a href={calendarUrl} class="nav-cta">Book a Call</a>
          </nav>
        </header>

        <section class="hero">
          <div class="eyebrow">
            <span class="edot"></span> For local service businesses in Boise &amp;
            the Treasure Valley <span class="edot"></span>
          </div>
          <h1 class="h1">
            <span class="h1-line">More local customers from Google</span>
            <span class="h1-line h1-accent"
              >— or we work free until you get them.</span
            >
          </h1>
          <p class="lede">
            We install the Google-first lead system end to end. 5 qualified
            leads in 60 days, guaranteed, or our recurring fee doesn't start.
          </p>
          <a href={calendarUrl} class="cta-primary">
            <span class="cta-body">
              <span class="cta-title">Book my free 45-minute install call</span>
              <span class="cta-sub"
                >You leave with a free Google Review App — yours forever.</span
              >
            </span>
            <svg class="chev" viewBox="0 0 24 24" aria-hidden="true"
              ><path d="M8.59 16.59L13.17 12 8.59 7.41 10 6l6 6-6 6z"
              ></path></svg
            >
          </a>
          <ul class="trust-strip">
            {
              trustStrip.map((t) => (
                <li>
                  <span class="check">✓</span> {t}
                </li>
              ))
            }
          </ul>
        </section>

        <section class="band band-alt">
          <div class="section-head">
            <span class="kicker">Local Search Reality</span>
            <h2 class="h2">
              The customers are already searching. The question is whether your
              business shows up.
            </h2>
          </div>
          <div class="stats">
            {
              stats.map((s) => (
                <div class="stat">
                  <div class="stat-n">{s.n}</div>
                  <div class="stat-l">{s.l}</div>
                </div>
              ))
            }
          </div>
          <p class="band-tail">
            If your business isn't installed as the answer to those searches,
            the business down the street is.
          </p>
        </section>

        <section class="band">
          <div class="section-head">
            <span class="kicker">Audience</span>
            <h2 class="h2">
              You're not behind because you're bad at marketing. You're behind
              because nobody installed the system.
            </h2>
          </div>
          <div class="audience-body">
            <p class="audience-intro">
              You already have customers. You're a good operator. The work you
              do is solid. The reason your phone isn't ringing the way it should
              isn't a skill problem.
            </p>
            <ul class="audience-list">
              {audiencePoints.map((p) => <li>{p}</li>)}
            </ul>
            <p class="audience-tail">
              Nobody can do all that themselves. The owners winning aren't doing
              it themselves either. They installed the system that does it for
              them.
            </p>
            <p class="audience-emph">
              That's the gap. Not your skill. Not your effort. The system.
            </p>
          </div>
        </section>

        <section class="band band-alt">
          <div class="section-head">
            <span class="kicker">Solution</span>
            <h2 class="h2">Why this works when the other things haven't.</h2>
          </div>
          <div class="differentiators">
            {
              differentiators.map((d) => (
                <div class="diff-card">
                  <div class="diff-h">{d.h}</div>
                  <div class="diff-p">{d.p}</div>
                </div>
              ))
            }
          </div>
        </section>

        <section class="band" id="about">
          <div class="section-head">
            <span class="kicker">About</span>
            <h2 class="h2">Why you can trust this is different.</h2>
          </div>
          <div class="identity">
            <div class="identity-body">
              <p>I'm Richard Prins. I run Velocity Web Studio out of Boise.</p>
              <p>
                I started the company after years of watching capable local
                service businesses pay for ads, SEO retainers, and website
                rebuilds — while the system that actually generates compounding
                leads sat un-installed in their business. Most agencies sell
                features. Almost nobody installs the end-to-end system.
              </p>
              <p>
                We do. One client per category, per city. Guaranteed in 60 days.
                Run by the team that builds it — no account managers, no
                handoffs, no layers between you and the people doing the work.
              </p>
              <p class="identity-emph">
                If you take nothing else from this page, take this: the leads
                you're losing this week already cost you to acquire. We just
                built the system so you stop losing them.
              </p>
            </div>
            <div class="identity-photo-wrap">
              <img
                class="identity-photo"
                src={headshot.src}
                alt="Richard Prins, Velocity Web Studio"
              />
              <div class="identity-cap">
                Richard Prins · Velocity Web Studio
              </div>
            </div>
          </div>
        </section>

        <section class="band band-alt">
          <div class="section-head">
            <span class="kicker">Testimonials</span>
            <h2 class="h2">How you know this is real.</h2>
          </div>
          <div class="testimonials">
            {
              testimonials.map((t) => (
                <figure class="testimonial">
                  <blockquote class="t-quote">{t.q}</blockquote>
                  <figcaption class="t-cap">
                    <span class="t-name">— {t.n}</span>
                    <span class="t-role">{t.r}</span>
                  </figcaption>
                </figure>
              ))
            }
          </div>
          <p class="testimonials-disclaimer">
            Testimonials reflect representative client outcomes. Real attributed
            reviews available on request.
          </p>
        </section>

        <section class="band band-close">
          <div class="close">
            <div class="section-head">
              <span class="kicker">Book your call</span>
              <h2 class="h2">Book your free 45-minute install call.</h2>
            </div>
            <div class="close-grid">
              {
                closeBlocks.map((b) => (
                  <div class="close-block">
                    <div class="close-block-h">{b.h}</div>
                    <p>{b.p}</p>
                  </div>
                ))
              }
            </div>
            <iframe
              src="https://api.velocitywebstudio.com/widget/booking/mcWyJi4NDQ1tg3JDZlYS"
              style="width: 100%;border:none;overflow: hidden;"
              scrolling="no"
              id="mcWyJi4NDQ1tg3JDZlYS_1778882671507"></iframe><br /><script
              is:inline
              src="https://api.velocitywebstudio.com/js/form_embed.js"
              type="text/javascript"></script>
          </div>
        </section>

        <footer class="footer">
          <div class="footer-row">
            <span class="fname">Velocity Web Studio</span>
            <span class="fdot" aria-hidden="true"></span>
            <span class="fmeta">Boise, Idaho</span>
          </div>
          <div class="footer-tagline">
            5 qualified leads in 60 days, or we work free until you do
          </div>
          <div class="footer-row footer-links">
            <a href="/links">Links</a>
            <span class="fsep" aria-hidden="true">·</span>
            <a href="/services">Services</a>
            <span class="fsep" aria-hidden="true">·</span>
            <a href="#about">About</a>
            <span class="fsep" aria-hidden="true">·</span>
            <a href={calendarUrl}>Book a Call</a>
          </div>
        </footer>
      </div>
    </div>

    <style is:global>
      *,
      *::before,
      *::after {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }

      :root {
        --orange: #ee4000;
        --orange-hv: #ff6b35;
        --orange-glow: rgba(238, 64, 0, 0.24);
      }

      [data-theme="dark"] {
        --bg: #0c0c0c;
        --bg-2: #161616;
        --bg-3: #202020;
        --fg: #ffffff;
        --fg-muted: #999999;
        --fg-dim: #555555;
        --border: rgba(255, 255, 255, 0.07);
        --border-hv: rgba(255, 255, 255, 0.13);
        --outer-bg: #080808;
        --band-alt: #0f0f0f;
      }

      [data-theme="light"] {
        --bg: #ffffff;
        --bg-2: #faf8f5;
        --bg-3: #f1ede7;
        --fg: #0c0c0c;
        --fg-muted: #4a4a4a;
        --fg-dim: #9a9a9a;
        --border: rgba(0, 0, 0, 0.08);
        --border-hv: rgba(0, 0, 0, 0.18);
        --outer-bg: #ffffff;
        --band-alt: #f7f4f1;
      }

      html,
      body {
        font-family: "DM Sans", sans-serif;
        background: var(--outer-bg);
        min-height: 100vh;
        color: var(--fg);
        transition:
          background 0.3s,
          color 0.3s;
      }

      .outer {
        display: flex;
        justify-content: center;
        min-height: 100vh;
        background: var(--outer-bg);
        transition: background 0.3s;
      }

      .page {
        width: 100%;
        background: var(--bg);
        color: var(--fg);
        position: relative;
        display: flex;
        flex-direction: column;
        transition:
          background 0.3s,
          color 0.3s;
      }

      /* ── CONTAINER SYSTEM ──
         Bands and hero are full-bleed; inner content is centered + constrained.
         Default container: 1120px (grids, multi-column).
         Narrow container: 760px (prose). */
      .topbar,
      .footer,
      .hero > *,
      .band > * {
        max-width: 1120px;
        margin-left: auto;
        margin-right: auto;
      }
      .hero > .eyebrow,
      .hero > .h1,
      .hero > .lede,
      .hero > .micro,
      .hero > .trust-strip,
      .band > .section-head,
      .band > .band-tail,
      .band > .audience-body,
      .band > .testimonials-disclaimer {
        max-width: 760px;
      }

      /* ── TOPBAR ── */
      .topbar {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 18px 24px 0;
        width: 100%;
      }
      .brand {
        font-weight: 800;
        font-size: 18px;
        letter-spacing: -0.5px;
        color: var(--fg);
        text-decoration: none;
      }
      .brand em {
        font-style: normal;
        color: var(--orange);
      }
      .nav {
        display: flex;
        align-items: center;
        gap: 16px;
      }
      .nav-cta {
        background: var(--orange);
        color: #fff;
        font-size: 13px;
        font-weight: 700;
        letter-spacing: 0.2px;
        padding: 9px 14px;
        border-radius: 99px;
        text-decoration: none;
        transition:
          background 0.15s,
          transform 0.1s;
        white-space: nowrap;
      }
      .nav-cta:hover {
        background: var(--orange-hv);
      }
      .nav-cta:active {
        transform: scale(0.97);
      }
      .theme-toggle {
        width: 34px;
        height: 34px;
        border-radius: 50%;
        border: 1px solid var(--border);
        background: transparent;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        transition:
          transform 0.15s,
          border-color 0.15s;
      }
      .theme-toggle:hover {
        transform: scale(1.06);
        border-color: var(--border-hv);
      }
      .theme-toggle svg {
        width: 14px;
        height: 14px;
        fill: var(--fg-muted);
      }
      .icon-sun {
        display: none;
      }
      .icon-moon {
        display: block;
      }
      [data-theme="light"] .icon-sun {
        display: block;
      }
      [data-theme="light"] .icon-moon {
        display: none;
      }

      /* ── HERO ── */
      .hero {
        padding: 56px 24px 56px;
        text-align: center;
      }
      .eyebrow {
        display: flex;
        align-items: center;
        gap: 10px;
        font-size: 11px;
        font-weight: 600;
        letter-spacing: 2.4px;
        text-transform: uppercase;
        color: var(--orange);
        margin-bottom: 24px;
        justify-content: center;
      }
      .edot {
        width: 4px;
        height: 4px;
        border-radius: 50%;
        background: var(--orange);
      }
      .h1 {
        font-family: "DM Sans", sans-serif;
        font-weight: 800;
        font-size: 40px;
        line-height: 1.06;
        letter-spacing: -1.2px;
        color: var(--fg);
        margin-bottom: 22px;
      }
      .h1-line {
        display: block;
      }
      .h1-accent {
        color: var(--orange);
      }
      .lede {
        font-size: 17px;
        line-height: 1.55;
        color: var(--fg-muted);
        max-width: 580px;
        margin: 0 auto 28px;
      }

      /* ── PRIMARY CTA ── */
      .cta-primary {
        display: flex;
        align-items: center;
        gap: 13px;
        background: var(--orange);
        color: #fff;
        border-radius: 14px;
        padding: 18px 18px;
        text-decoration: none;
        position: relative;
        overflow: hidden;
        box-shadow: 0 6px 24px var(--orange-glow);
        transition:
          background 0.18s,
          box-shadow 0.18s,
          transform 0.12s;
        max-width: 480px;
        margin: 0 auto;
        text-align: left;
      }
      .cta-primary::before {
        content: "";
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        height: 50%;
        background: linear-gradient(
          180deg,
          rgba(255, 255, 255, 0.09),
          transparent
        );
        pointer-events: none;
      }
      .cta-primary:hover {
        background: var(--orange-hv);
        box-shadow: 0 10px 32px rgba(238, 64, 0, 0.35);
      }
      .cta-primary:active {
        transform: scale(0.98);
      }
      .cta-primary-lg {
        max-width: 560px;
      }
      .cta-body {
        flex: 1;
        display: flex;
        flex-direction: column;
        gap: 3px;
      }
      .cta-title {
        font-weight: 700;
        font-size: 15px;
        line-height: 1.2;
      }
      .cta-sub {
        font-size: 12.5px;
        opacity: 0.85;
        font-weight: 300;
      }
      .chev {
        width: 16px;
        height: 16px;
        fill: #fff;
        flex-shrink: 0;
      }

      /* ── TRUST STRIP ── */
      .trust-strip {
        list-style: none;
        display: flex;
        flex-wrap: wrap;
        justify-content: center;
        gap: 10px 22px;
        margin-top: 28px;
      }
      .trust-strip li {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        font-size: 13px;
        color: var(--fg-muted);
      }
      .check {
        color: var(--orange);
        font-weight: 700;
      }

      /* ── BANDS ── */
      .band {
        padding: 64px 24px;
        border-top: 1px solid var(--border);
      }
      .band-alt {
        background: var(--band-alt);
      }
      .section-head {
        margin-bottom: 36px;
        text-align: center;
      }
      .kicker {
        display: inline-block;
        font-size: 10.5px;
        font-weight: 700;
        letter-spacing: 2.4px;
        text-transform: uppercase;
        color: var(--orange);
        margin-bottom: 14px;
      }
      .h2 {
        font-family: "DM Sans", sans-serif;
        font-weight: 700;
        font-size: 26px;
        line-height: 1.2;
        letter-spacing: -0.6px;
        color: var(--fg);
      }

      /* ── STATS ── */
      .stats {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 28px 18px;
        margin-bottom: 36px;
      }
      .stat {
        text-align: center;
      }
      .stat-n {
        font-weight: 800;
        font-size: 48px;
        line-height: 1;
        letter-spacing: -1.6px;
        color: var(--orange);
        margin-bottom: 10px;
      }
      .stat-l {
        font-size: 13.5px;
        line-height: 1.45;
        color: var(--fg-muted);
      }
      .band-tail {
        text-align: center;
        font-size: 16px;
        line-height: 1.6;
        color: var(--fg);
      }

      /* ── AUDIENCE ── */
      .audience-body {
        display: flex;
        flex-direction: column;
        gap: 22px;
      }
      .audience-intro {
        font-size: 18px;
        line-height: 1.55;
        color: var(--fg);
        font-weight: 500;
      }
      .audience-list {
        list-style: none;
        display: flex;
        flex-direction: column;
        gap: 12px;
      }
      .audience-list li {
        position: relative;
        padding-left: 28px;
        font-size: 15.5px;
        line-height: 1.6;
        color: var(--fg);
      }
      .audience-list li::before {
        content: "→";
        position: absolute;
        left: 0;
        top: 0;
        color: var(--orange);
        font-weight: 700;
      }
      .audience-tail {
        font-size: 15.5px;
        line-height: 1.65;
        color: var(--fg-muted);
      }
      .audience-emph {
        font-size: 20px;
        font-weight: 600;
        line-height: 1.35;
        color: var(--fg);
        border-left: 3px solid var(--orange);
        padding-left: 16px;
        margin-top: 6px;
      }

      /* ── DIFFERENTIATORS ── */
      .differentiators {
        display: grid;
        grid-template-columns: 1fr;
        gap: 16px;
      }
      .diff-card {
        padding: 24px 22px;
        background: var(--bg-2);
        border: 1px solid var(--border);
        border-radius: 14px;
      }
      .diff-h {
        font-weight: 700;
        font-size: 18px;
        line-height: 1.3;
        letter-spacing: -0.3px;
        color: var(--orange);
        margin-bottom: 10px;
      }
      .diff-p {
        font-size: 14.5px;
        line-height: 1.6;
        color: var(--fg-muted);
      }

      /* ── IDENTITY / ABOUT ── */
      .identity {
        display: grid;
        grid-template-columns: 1fr;
        gap: 32px;
      }
      .identity-body {
        display: flex;
        flex-direction: column;
        gap: 16px;
        font-size: 15.5px;
        line-height: 1.7;
        color: var(--fg-muted);
      }
      .identity-body p {
        color: var(--fg-muted);
      }
      .identity-emph {
        font-size: 17px !important;
        font-weight: 500;
        color: var(--fg) !important;
        border-left: 3px solid var(--orange);
        padding-left: 16px;
        margin-top: 6px;
      }
      .identity-photo-wrap {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 10px;
      }
      .identity-photo {
        width: 100%;
        max-width: 340px;
        aspect-ratio: 1;
        object-fit: cover;
        object-position: center 18%;
        border-radius: 16px;
        border: 1px solid var(--border);
      }
      .identity-cap {
        font-size: 12.5px;
        color: var(--fg-dim);
        letter-spacing: 0.3px;
        text-align: center;
      }

      /* ── TESTIMONIALS ── */
      .testimonials {
        display: grid;
        grid-template-columns: 1fr;
        gap: 16px;
      }
      .testimonial {
        padding: 24px 22px;
        background: var(--bg-2);
        border: 1px solid var(--border);
        border-radius: 14px;
        display: flex;
        flex-direction: column;
        gap: 18px;
      }
      .t-quote {
        font-size: 15.5px;
        line-height: 1.6;
        color: var(--fg);
        font-style: italic;
        position: relative;
        padding-left: 6px;
      }
      .t-quote::before {
        content: "“";
        position: absolute;
        left: -6px;
        top: -16px;
        font-family: Georgia, serif;
        font-size: 44px;
        color: var(--orange);
        line-height: 1;
        opacity: 0.7;
      }
      .t-cap {
        display: flex;
        flex-direction: column;
        gap: 2px;
      }
      .t-name {
        font-weight: 700;
        font-size: 14px;
        color: var(--fg);
      }
      .t-role {
        font-size: 12.5px;
        color: var(--fg-muted);
      }
      .testimonials-disclaimer {
        margin-top: 28px;
        text-align: center;
        font-size: 12px;
        color: var(--fg-dim);
        font-style: italic;
      }

      /* ── CLOSE ── */
      .band-close {
        padding-bottom: 80px;
      }
      .close {
        display: flex;
        flex-direction: column;
        gap: 8px;
      }
      .close-grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 16px;
        margin: 8px 0 32px;
      }
      .close-block {
        padding: 22px 22px;
        background: var(--bg-2);
        border: 1px solid var(--border);
        border-radius: 12px;
      }
      .close-block-h {
        font-weight: 700;
        font-size: 12px;
        letter-spacing: 1.4px;
        text-transform: uppercase;
        color: var(--orange);
        margin-bottom: 10px;
      }
      .close-block p {
        font-size: 14.5px;
        line-height: 1.6;
        color: var(--fg-muted);
      }

      /* ── FOOTER ── */
      .footer {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 12px;
        text-align: center;
        border-top: 1px solid var(--border);
        padding: 36px 24px 48px;
        width: 100%;
      }
      .footer-row {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        flex-wrap: wrap;
        justify-content: center;
        font-size: 13px;
        color: var(--fg-muted);
      }
      .fname {
        font-weight: 700;
        color: var(--fg);
      }
      .fdot {
        width: 3px;
        height: 3px;
        border-radius: 50%;
        background: var(--orange);
        opacity: 0.65;
      }
      .fmeta {
        color: var(--fg-muted);
      }
      .footer-tagline {
        font-size: 13px;
        color: var(--fg-muted);
        font-style: italic;
      }
      .footer-links a {
        color: var(--fg-muted);
        text-decoration: none;
        transition: color 0.15s;
      }
      .footer-links a:hover {
        color: var(--orange);
      }
      .fsep {
        color: var(--fg-dim);
      }

      /* ── RESPONSIVE ── */
      @media (min-width: 640px) {
        .h1 {
          font-size: 54px;
          letter-spacing: -1.8px;
        }
        .h2 {
          font-size: 32px;
        }
        .hero {
          padding: 96px 36px 80px;
        }
        .band {
          padding: 88px 36px;
        }
        .topbar {
          padding: 22px 36px 0;
        }
        .footer {
          padding: 40px 36px 56px;
        }
        .stats {
          grid-template-columns: repeat(4, 1fr);
          gap: 24px 18px;
        }
        .stat-n {
          font-size: 56px;
        }
        .differentiators {
          grid-template-columns: repeat(2, 1fr);
        }
        .diff-card:nth-child(5) {
          grid-column: 1 / -1;
        }
        .testimonials {
          grid-template-columns: repeat(3, 1fr);
        }
        .close-grid {
          grid-template-columns: repeat(3, 1fr);
        }
      }

      @media (min-width: 880px) {
        .identity {
          grid-template-columns: 1.4fr 1fr;
          align-items: start;
          gap: 56px;
        }
      }

      @media (min-width: 960px) {
        .h1 {
          font-size: 64px;
          letter-spacing: -2.2px;
        }
        .h2 {
          font-size: 36px;
          letter-spacing: -0.8px;
        }
        .hero {
          padding: 120px 48px 96px;
        }
        .band {
          padding: 104px 48px;
        }
        .topbar {
          padding: 26px 48px 0;
        }
        .footer {
          padding: 48px 48px 64px;
        }
        .stat-n {
          font-size: 72px;
          letter-spacing: -2.4px;
        }
      }
    </style>

    <script is:inline>
      (function () {
        const html = document.documentElement;
        const btn = document.getElementById("themeToggle");
        const KEY = "vws-theme";

        const saved = localStorage.getItem(KEY);
        const sys = window.matchMedia("(prefers-color-scheme: light)").matches
          ? "light"
          : "dark";
        html.setAttribute("data-theme", saved ?? sys);

        btn.addEventListener("click", () => {
          const next =
            html.getAttribute("data-theme") === "dark" ? "light" : "dark";
          html.setAttribute("data-theme", next);
          localStorage.setItem(KEY, next);
        });

        window
          .matchMedia("(prefers-color-scheme: light)")
          .addEventListener("change", (e) => {
            if (!localStorage.getItem(KEY)) {
              html.setAttribute("data-theme", e.matches ? "light" : "dark");
            }
          });
      })();
    </script>
  </body>
</html>
