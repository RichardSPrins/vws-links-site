---
// src/pages/links.astro
// VWS personal link-in-bio page
// Swap hero src, calendar href, and product hrefs before launch
import heashot from "../assets/headshot.png";

export const prerender = true;
---

<!doctype html>
<html lang="en" data-theme="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Richard Prins Jr. — Velocity Web Studio</title>
    <meta
      name="description"
      content="Marketing and lead-generation systems for Boise local businesses. Bring in more leads, win more customers, grow without the guesswork."
    />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link
      href="https://fonts.googleapis.com/css2?family=Syne:wght@700;800&family=DM+Sans:wght@300;400;500&display=swap"
      rel="stylesheet"
    />
  </head>

  <body>
    <div class="outer">
      <div class="page">
        <button
          class="theme-toggle"
          id="themeToggle"
          aria-label="Toggle light/dark mode"
        >
          <svg class="icon-moon" viewBox="0 0 24 24" aria-hidden="true"
            ><path d="M21 12.79A9 9 0 1 1 11.21 3a7 7 0 0 0 9.79 9.79z"
            ></path></svg
          >
          <svg class="icon-sun" viewBox="0 0 24 24" aria-hidden="true"
            ><path
              d="M12 17a5 5 0 1 0 0-10 5 5 0 0 0 0 10zm0-14a1 1 0 0 1 1 1v1a1 1 0 1 1-2 0V4a1 1 0 0 1 1-1zm0 16a1 1 0 0 1 1 1v1a1 1 0 1 1-2 0v-1a1 1 0 0 1 1-1zm9-9a1 1 0 0 1 0 2h-1a1 1 0 1 1 0-2h1zM5 12a1 1 0 0 1-1 1H3a1 1 0 1 1 0-2h1a1 1 0 0 1 1 1zm12.66-6.24a1 1 0 0 1 0 1.41l-.71.71a1 1 0 1 1-1.41-1.41l.71-.71a1 1 0 0 1 1.41 0zM7.05 17.66a1 1 0 0 1 0 1.41l-.71.71a1 1 0 1 1-1.41-1.41l.71-.71a1 1 0 0 1 1.41 0zm11.32 0a1 1 0 0 1-1.41 1.41l-.71-.71a1 1 0 1 1 1.41-1.41l.71.71zM7.05 6.34a1 1 0 0 1-1.41 0l-.71-.71a1 1 0 0 1 1.41-1.41l.71.71a1 1 0 0 1 0 1.41z"
            ></path></svg
          >
        </button>

        <div class="hero">
          <img class="hero-img" src={heashot.src} alt="Richard Prins Jr." />
          <div class="hero-fade" aria-hidden="true"></div>
          <div class="hero-line" aria-hidden="true"></div>
          <div class="identity">
            <div class="name">Richard <em>Prins Jr.</em></div>
            <div class="meta-row">
              <span class="handle">@velocitywebstudio</span>
              <span class="sep" aria-hidden="true">·</span>
              <span class="location">
                <svg viewBox="0 0 24 24" aria-hidden="true"
                  ><path
                    d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"
                  ></path></svg
                >
                Boise, Idaho
              </span>
            </div>
          </div>
        </div>

        <div class="bio-block">
          <p class="bio">
            Helping <strong>Boise local businesses</strong> bring in more leads,
            win more customers, and grow without the guesswork.
          </p>
        </div>

        <div class="links">
          <div class="divider">
            <span class="dline"></span><span class="dlabel">Start here</span
            ><span class="dline"></span>
          </div>

          <a href="https://api.velocitywebstudio.com/widget/booking/mcWyJi4NDQ1tg3JDZlYS" class="cta-primary">
            <span class="cta-icon">
              <svg viewBox="0 0 24 24" aria-hidden="true"
                ><path
                  d="M9 11H7v2h2v-2zm4 0h-2v2h2v-2zm4 0h-2v2h2v-2zm2-7h-1V2h-2v2H8V2H6v2H5c-1.11 0-1.99.9-1.99 2L3 20c0 1.1.89 2 2 2h14c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 16H5V9h14v11z"
                ></path></svg
              >
            </span>
            <span class="cta-body">
              <span class="cta-title">Book my free 45-minute install call</span>
              <span class="cta-sub"
                >You leave with a free Google Review App — yours forever</span
              >
            </span>
            <svg class="chev" viewBox="0 0 24 24" aria-hidden="true"
              ><path d="M8.59 16.59L13.17 12 8.59 7.41 10 6l6 6-6 6z"
              ></path></svg
            >
          </a>

          <div class="divider">
            <span class="dline"></span><span class="dlabel">Free resources</span
            ><span class="dline"></span>
          </div>

          <a href="/website-grade" class="link-card">
            <span class="licon ic-orange">🎯</span>
            <span class="lbody">
              <span class="ltitle"
                >Free Website Grader <span class="pill pill-orange">Free</span
                ></span
              >
              <span class="lsub"
                >See your site's score in seconds — find what's costing you
                customers</span
              >
            </span>
            <svg class="chev" viewBox="0 0 24 24" aria-hidden="true"
              ><path d="M8.59 16.59L13.17 12 8.59 7.41 10 6l6 6-6 6z"
              ></path></svg
            >
          </a>

          <div class="divider">
            <span class="dline"></span><span class="dlabel">Explore</span><span
              class="dline"></span>
          </div>

          <a href="https://hiddengemsboise.com" class="link-card">
            <span class="licon ic-green">💎</span>
            <span class="lbody">
              <span class="ltitle">Hidden Gems Boise</span>
              <span class="lsub"
                >The best local businesses in the city worth knowing</span
              >
            </span>
            <svg class="chev" viewBox="0 0 24 24" aria-hidden="true"
              ><path d="M8.59 16.59L13.17 12 8.59 7.41 10 6l6 6-6 6z"
              ></path></svg
            >
          </a>

          <a href="#" class="link-card">
            <span class="licon ic-blue">📈</span>
            <span class="lbody">
              <span class="ltitle">Client Results</span>
              <span class="lsub"
                >Before and after — real local business growth</span
              >
            </span>
            <svg class="chev" viewBox="0 0 24 24" aria-hidden="true"
              ><path d="M8.59 16.59L13.17 12 8.59 7.41 10 6l6 6-6 6z"
              ></path></svg
            >
          </a>
        </div>

        <footer class="footer">
          <span class="fdot" aria-hidden="true"></span>
          <span class="fname">Velocity Web Studio</span>
          <span class="fdot" aria-hidden="true"></span>
        </footer>
      </div>
    </div>
  </body>
</html>

<style is:global>
  *,
  *::before,
  *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  :root {
    --orange: #ee4000;
    --orange-hv: #ff6b35;
    --orange-glow: rgba(238, 64, 0, 0.24);
  }

  [data-theme="dark"] {
    --bg: #0c0c0c;
    --bg-2: #161616;
    --bg-3: #202020;
    --fg: #ffffff;
    --fg-muted: #999999;
    --fg-dim: #555555;
    --border: rgba(255, 255, 255, 0.07);
    --border-hv: rgba(255, 255, 255, 0.13);
    --fade-color: #0c0c0c;
    --outer-bg: #080808;
    --img-filter: brightness(0.72) saturate(0.88);
  }

  [data-theme="light"] {
    --bg: #f4f1ee;
    --bg-2: #ffffff;
    --bg-3: #edeae7;
    --fg: #111111;
    --fg-muted: #555555;
    --fg-dim: #aaaaaa;
    --border: rgba(0, 0, 0, 0.08);
    --border-hv: rgba(0, 0, 0, 0.16);
    --fade-color: #f4f1ee;
    --outer-bg: #e8e5e1;
    --img-filter: brightness(0.88) saturate(0.9);
  }

  html,
  body {
    font-family: "DM Sans", sans-serif;
    background: var(--outer-bg);
    min-height: 100vh;
    transition:
      background 0.3s,
      color 0.3s;
  }

  /* centered column — mobile fills full width, wider screens get a card */
  .outer {
    display: flex;
    justify-content: center;
    min-height: 100vh;
    background: var(--outer-bg);
    transition: background 0.3s;
  }

  .page {
    width: 100%;
    max-width: 480px;
    background: var(--bg);
    color: var(--fg);
    position: relative;
    display: flex;
    flex-direction: column;
    box-shadow: 0 0 80px rgba(0, 0, 0, 0.35);
    transition:
      background 0.3s,
      color 0.3s;
  }

  /* ── THEME TOGGLE ── */
  .theme-toggle {
    position: absolute;
    top: 14px;
    right: 14px;
    z-index: 20;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    border: 1px solid rgba(255, 255, 255, 0.2);
    background: rgba(0, 0, 0, 0.32);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: transform 0.15s;
  }
  .theme-toggle:hover {
    transform: scale(1.08);
  }
  .theme-toggle:active {
    transform: scale(0.95);
  }
  .theme-toggle svg {
    width: 15px;
    height: 15px;
    fill: rgba(255, 255, 255, 0.85);
  }
  .icon-sun {
    display: none;
  }
  .icon-moon {
    display: block;
  }
  [data-theme="light"] .icon-sun {
    display: block;
  }
  [data-theme="light"] .icon-moon {
    display: none;
  }

  /* ── HERO ── */
  .hero {
    position: relative;
    width: 100%;
    height: 380px;
    overflow: hidden;
    flex-shrink: 0;
    animation: fadeIn 0.4s ease both;
  }
  .hero-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
    display: block;
    filter: var(--img-filter);
    transition: filter 0.3s;
  }
  .hero-line {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 2px;
    background: linear-gradient(
      90deg,
      transparent,
      var(--orange) 35%,
      var(--orange-hv) 65%,
      transparent
    );
    z-index: 3;
  }
  .hero-fade {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 68%;
    background: linear-gradient(
      to bottom,
      transparent 0%,
      var(--fade-color) 100%
    );
    z-index: 2;
    transition: background 0.3s;
  }

  /* ── IDENTITY overlaid bottom-left on hero ── */
  .identity {
    position: absolute;
    bottom: 0;
    left: 0;
    padding: 0 22px 20px;
    z-index: 4;
  }
  .name {
    font-family: "Syne", sans-serif;
    font-weight: 800;
    font-size: 28px;
    letter-spacing: -0.8px;
    line-height: 1.05;
    color: #ffffff;
    text-shadow: 0 2px 16px rgba(0, 0, 0, 0.55);
    margin-bottom: 7px;
  }
  .name em {
    font-style: normal;
    color: var(--orange);
  }

  .meta-row {
    display: flex;
    align-items: center;
    gap: 7px;
    flex-wrap: wrap;
  }
  .handle {
    font-size: 12px;
    font-weight: 500;
    color: rgba(255, 255, 255, 0.75);
  }
  .sep {
    color: rgba(255, 255, 255, 0.35);
    font-size: 12px;
  }
  .location {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    font-size: 12px;
    color: rgba(255, 255, 255, 0.65);
  }
  [data-theme="light"] .handle {
    color: rgba(0, 0, 0, 0.72);
  }
  [data-theme="light"] .sep {
    color: rgba(0, 0, 0, 0.35);
  }
  [data-theme="light"] .location {
    color: rgba(0, 0, 0, 0.6);
  }
  .location svg {
    width: 10px;
    height: 10px;
    fill: var(--orange);
    flex-shrink: 0;
  }

  /* ── BIO ── */
  .bio-block {
    padding: 18px 22px 4px;
    animation: fadeUp 0.4s ease 0.05s both;
  }
  .bio {
    font-size: 13.5px;
    line-height: 1.65;
    color: var(--fg-muted);
    transition: color 0.3s;
  }
  .bio strong {
    color: var(--fg);
    font-weight: 500;
  }

  /* ── LINKS ── */
  .links {
    padding: 0 22px 16px;
    flex: 1;
  }

  .divider {
    display: flex;
    align-items: center;
    gap: 10px;
    margin: 22px 0 11px;
  }
  .dline {
    flex: 1;
    height: 1px;
    background: var(--border);
    transition: background 0.3s;
  }
  .dlabel {
    font-size: 9.5px;
    font-weight: 600;
    letter-spacing: 2.5px;
    text-transform: uppercase;
    color: var(--fg-dim);
    white-space: nowrap;
    transition: color 0.3s;
  }

  /* primary CTA */
  .cta-primary {
    display: flex;
    align-items: center;
    gap: 13px;
    background: var(--orange);
    color: #fff;
    border-radius: 15px;
    padding: 16px 15px;
    text-decoration: none;
    position: relative;
    overflow: hidden;
    box-shadow: 0 6px 24px var(--orange-glow);
    transition:
      background 0.18s,
      box-shadow 0.18s,
      transform 0.12s;
    animation: fadeUp 0.4s ease 0.08s both;
  }
  .cta-primary::before {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 50%;
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.09), transparent);
    pointer-events: none;
  }
  .cta-primary:hover {
    background: var(--orange-hv);
    box-shadow: 0 10px 32px rgba(238, 64, 0, 0.35);
  }
  .cta-primary:active {
    transform: scale(0.98);
  }

  .cta-icon {
    width: 42px;
    height: 42px;
    background: rgba(255, 255, 255, 0.16);
    border-radius: 11px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  .cta-icon svg {
    width: 19px;
    height: 19px;
    fill: #fff;
  }
  .cta-body {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 3px;
  }
  .cta-title {
    font-family: "Syne", sans-serif;
    font-weight: 700;
    font-size: 14.5px;
    line-height: 1.2;
  }
  .cta-sub {
    font-size: 12px;
    opacity: 0.82;
    font-weight: 300;
  }

  /* link cards */
  .link-card {
    display: flex;
    align-items: center;
    gap: 12px;
    background: var(--bg-2);
    border: 1px solid var(--border);
    border-radius: 13px;
    padding: 13px 14px;
    text-decoration: none;
    color: var(--fg);
    margin-bottom: 8px;
    transition:
      background 0.15s,
      border-color 0.15s,
      transform 0.1s,
      color 0.3s;
  }
  .link-card:last-child {
    margin-bottom: 0;
  }
  .link-card:hover {
    background: var(--bg-3);
    border-color: var(--border-hv);
  }
  .link-card:active {
    transform: scale(0.985);
  }

  .licon {
    width: 38px;
    height: 38px;
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    font-size: 17px;
    line-height: 1;
  }
  .ic-orange {
    background: rgba(238, 64, 0, 0.12);
  }
  .ic-gold {
    background: rgba(212, 175, 55, 0.1);
  }
  .ic-green {
    background: rgba(52, 211, 153, 0.1);
  }
  .ic-blue {
    background: rgba(96, 165, 250, 0.1);
  }
  .ic-purple {
    background: rgba(167, 139, 250, 0.1);
  }

  .lbody {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 2px;
    min-width: 0;
  }
  .ltitle {
    font-family: "Syne", sans-serif;
    font-weight: 600;
    font-size: 13px;
    line-height: 1.2;
    display: flex;
    align-items: center;
    gap: 6px;
    flex-wrap: wrap;
  }
  .lsub {
    font-size: 11.5px;
    color: var(--fg-muted);
    transition: color 0.3s;
  }

  .pill {
    font-size: 8.5px;
    font-weight: 700;
    letter-spacing: 0.4px;
    text-transform: uppercase;
    padding: 2px 6px;
    border-radius: 20px;
    white-space: nowrap;
    flex-shrink: 0;
  }
  .pill-orange {
    background: rgba(238, 64, 0, 0.14);
    color: var(--orange);
  }
  .pill-gold {
    background: rgba(212, 175, 55, 0.12);
    color: #c9a84c;
  }
  .pill-dim {
    background: var(--bg-3);
    color: var(--fg-muted);
    border: 1px solid var(--border);
  }

  .chev {
    width: 14px;
    height: 14px;
    fill: var(--fg-dim);
    flex-shrink: 0;
    transition: fill 0.2s;
  }

  /* ── FOOTER ── */
  .footer {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    padding: 24px 0 36px;
  }
  .fdot {
    width: 3px;
    height: 3px;
    border-radius: 50%;
    background: var(--orange);
    opacity: 0.55;
  }
  .fname {
    font-family: "Syne", sans-serif;
    font-weight: 700;
    font-size: 11px;
    color: var(--fg-dim);
    letter-spacing: 0.3px;
    transition: color 0.3s;
  }

  /* ── ANIMATIONS ── */
  @keyframes fadeIn {
    from {
      opacity: 0;
    }
    to {
      opacity: 1;
    }
  }
  @keyframes fadeUp {
    from {
      opacity: 0;
      transform: translateY(12px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .link-card:nth-child(1) {
    animation: fadeUp 0.35s ease 0.1s both;
  }
  .link-card:nth-child(2) {
    animation: fadeUp 0.35s ease 0.14s both;
  }
  .link-card:nth-child(3) {
    animation: fadeUp 0.35s ease 0.18s both;
  }
  .link-card:nth-child(4) {
    animation: fadeUp 0.35s ease 0.22s both;
  }
  .link-card:nth-child(5) {
    animation: fadeUp 0.35s ease 0.26s both;
  }
  .link-card:nth-child(6) {
    animation: fadeUp 0.35s ease 0.3s both;
  }
</style>

<script is:inline>
  (function () {
    const html = document.documentElement;
    const btn = document.getElementById("themeToggle");
    const KEY = "vws-theme";

    // 1. Respect saved preference, fall back to OS
    const saved = localStorage.getItem(KEY);
    const sys = window.matchMedia("(prefers-color-scheme: light)").matches
      ? "light"
      : "dark";
    html.setAttribute("data-theme", saved ?? sys);

    // 2. Toggle on click
    btn.addEventListener("click", () => {
      const next =
        html.getAttribute("data-theme") === "dark" ? "light" : "dark";
      html.setAttribute("data-theme", next);
      localStorage.setItem(KEY, next);
    });

    // 3. Follow OS changes only if user hasn't manually chosen
    window
      .matchMedia("(prefers-color-scheme: light)")
      .addEventListener("change", (e) => {
        if (!localStorage.getItem(KEY)) {
          html.setAttribute("data-theme", e.matches ? "light" : "dark");
        }
      });
  })();
</script>
