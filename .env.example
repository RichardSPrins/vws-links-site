# Webhook URL that receives lead data after a website grade is run.
# Server-only — the API route at /api/grade posts the lead directly.
GHL_WEBHOOK_URL=

# Comma-separated list of allowed origins for /api/grade (e.g.
# "https://velocitywebstudio.com,https://www.velocitywebstudio.com").
# Leave blank in dev to skip origin checking.
ALLOWED_ORIGINS=

# Cloudflare Turnstile keys (https://dash.cloudflare.com/?to=/:account/turnstile).
# Site key is public (rendered into the widget); secret stays server-only.
PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
